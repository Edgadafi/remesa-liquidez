# ═══════════════════════════════════════════════════════════════════════════
#  Remesa LiquidezIA — Variables de entorno unificadas del monorepo
#
#  Uso:
#    cp .env.example .env          → llena los valores reales
#    npm run sync-env              → propaga a web/.env y backend/.env
#
#  Reglas de seguridad:
#    - Nunca commitear .env (está en .gitignore)
#    - Las vars NEXT_PUBLIC_* son expuestas al browser — solo datos públicos
#    - ELEVENLABS_API_KEY, KEEPER_PRIVATE_KEY, RENDER_INTERNAL_SECRET → server-side only
# ═══════════════════════════════════════════════════════════════════════════

# ── Solana / Red ───────────────────────────────────────────────────────────
SOLANA_CLUSTER=devnet
# RPC privado recomendado en producción (Helius, QuickNode, Triton)
SOLANA_RPC_URL=https://api.devnet.solana.com
# Expuesto al browser (wallet-adapter, MWA connection)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# ── Programa Anchor ────────────────────────────────────────────────────────
# Program ID del contrato remesa_liquidez en devnet
NEXT_PUBLIC_PROGRAM_ID=Fprb6jTLfjXfZ6yuWzS7LVXxwVvPbPgPZiEqDEL9bRfj

# ── SPL Tokens ─────────────────────────────────────────────────────────────
# USDC devnet: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# USDC mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ── Frontend (Vercel) ──────────────────────────────────────────────────────
# URL canónica — usada en metadataBase, OG tags y MWA appIdentity
NEXT_PUBLIC_SITE_URL=https://web-coral-pi-66.vercel.app
NEXT_PUBLIC_BLINK_BASE_URL=https://web-coral-pi-66.vercel.app
# Iconos por Action (opcional — usa Unsplash defaults si se omite)
NEXT_PUBLIC_BLINK_ICON_URL=
NEXT_PUBLIC_VERIFY_ICON_URL=

# ── Backend TIA (Render / local) ───────────────────────────────────────────
# URL del servicio remesa-tia-backend (Semana 1 Bridge) — reemplaza remesa-blink-backend cuando esté live
RENDER_BACKEND_URL=https://remesa-tia-backend.onrender.com
# Bot WhatsApp Baileys (remesa-blink-bot en Render)
BOT_INTERNAL_URL=https://remesa-blink-bot.onrender.com
BOT_INTERNAL_SECRET=
# Si true, /api/tia/notify responde 200 aunque el bot esté offline (solo demo local)
TIA_ALLOW_NOTIFY_WITHOUT_BOT=false
# Manual override cuando webhooks fallan en test en vivo (Do Things That Don't Scale)
TIA_MANUAL_OVERRIDE_SECRET=
# Comercio piloto hardcoded si falla routing de tiendas (demo-merchant-1 devnet)
NEXT_PUBLIC_FALLBACK_MERCHANT_PUBKEY=9973FHqsvU5govuEiWgFmjcU6bbMNPTQceGEjrpkiV9i
# URL para Blink links en WhatsApp (backend TIA)
BLINK_BASE_URL=https://web-coral-pi-66.vercel.app

# Ruta notify TIA en Render (opcional; default: /api/tia/notify con fallback /api/lidia/notify)
# TIA_NOTIFY_PATH=/api/tia/notify

# ── ElevenLabs TTS ────────────────────────────────────────────────────────
# API key server-side — NUNCA anteponer NEXT_PUBLIC_
ELEVENLABS_API_KEY=
# Voz de TIA: Sarah ES (femenina, cálida)
#   EXAVITQu4vr4xnSDxMaL → Sarah  (default)
#   onwK4e9ZLuTAKqWW03F9 → Daniel
#   pNInz6obpgDQGcFmaJgB → Adam
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ── Keeper / Scripts devnet ────────────────────────────────────────────────
# Keypair JSON del sender authority para scripts E2E y Keeper bot
# Generar: solana-keygen new --outfile ~/.config/solana/keeper.json
KEEPER_PRIVATE_KEY=
# Receptor de demo para tests E2E
E2E_RECEIVER_PUBKEY=

# ── World ID (futuro) ──────────────────────────────────────────────────────
WORLD_ID_APP_ID=
WORLD_ID_ACTION=verify-remesa
